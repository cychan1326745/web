<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DSE物理本地題庫</title>
  <style>
    *{box-sizing:border-box;font-family:system-ui,sans-serif}
    body{max-width:950px;margin:0 auto;padding:20px;background:#f5f7fa}
    .filter-panel{background:#fff;padding:16px;border-radius:10px;display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-bottom:24px;box-shadow:0 1px 6px rgba(0,0,0,0.05)}
    select,input,button{padding:9px;border:1px solid #ccc;border-radius:6px;font-size:14px}
    button{background:#2563eb;color:white;border:none;cursor:pointer}
    button:hover{background:#1d4ed8}
    .question-card{background:white;padding:16px;border-radius:8px;margin:12px 0;box-shadow:0 1px 4px rgba(0,0,0,0.05)}
    .question-card img{width:100%;max-width:750px;margin:10px 0}
    .meta{font-size:13px;color:#666;margin-bottom:8px}
    .answer-bar{margin-top:12px;display:flex;gap:10px}
    .ans-btn{flex:1;padding:12px 0;font-size:16px;font-weight:bold;background:#b8e1ff;color:#000;border:1px solid #99ccff}
    .ans-btn.correct{background:#28a745;color:#fff}
    .ans-btn.wrong{background:#dc3545;color:#fff}
    .result-text{margin-top:10px;font-weight:bold;font-size:17px;color:#dc3545}
    .explain{margin-top:10px;padding:10px;background:#f0f4ff;border-radius:6px;font-size:16px;display:none}
    .stat{margin-top:12px;font-size:14px;color:#444;background:#eef6ff;padding:6px 10px;border-radius:6px}
    .page-bar{margin-top:20px;text-align:center}
    .page-btn{margin:0 4px;padding:8px 14px}
  </style>
</head>
<body>
<h2>DSE物理題庫｜本地版</h2>

<div class="filter-panel">
  <select id="source">
    <option value="">全部來源</option>
    <option value="book01">book01</option>
  </select>
  <select id="chapter">
    <option value="">全部章節</option>
    <option value="ch02">ch02</option>
    <option value="ch03">ch03</option>
    <option value="ch04">ch04</option>
  </select>
  <input type="number" id="q_no" placeholder="題號">
  <select id="diff">
    <option value="">全部難度</option>
    <option value="easy">easy</option>
    <option value="avg">avg</option>
    <option value="dif">dif</option>
  </select>
  <button onclick="loadFilteredQuestions()">查詢題目</button>
</div>

<div id="questionList">載入中...</div>
<div class="page-bar" id="pageBar"></div>

