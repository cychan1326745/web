        "exp_link": null,
        "ans": "A",
        "explain": "所有溫度的物體都會同時發出輻射和吸收輻射。",
        "diff": "avg"
      },
      {
        "id": 31,
        "subject": "phy",
        "source": "book01",
        "chapter": "ch02",
