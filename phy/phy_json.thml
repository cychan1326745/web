        "exp_link": null,
        "ans": "B",
        "explain": "如果電熱器提供的部分能量散失到四周，汽化了的水的質量比理論值小。根據，實驗結果會比標準值大。∴ (1) 不正確。如果有些水在沸騰時濺到杯外，水減少的質量會比汽化了的水的質量大。根據，實驗結果會比標準值小。∴ (2) 正確。如果部分蒸汽凝結成水並流回杯中，水減少的質量會比汽化了的水的質量小。根據，實驗結果會比標準值大。∴ (3) 不正確。",
        "diff": "dif"
      }
    ]
  ;

const PER_PAGE = 20;
let currentPage = 1;

function getRecord() {
  const raw = localStorage.getItem("q_records");
  return raw ? JSON.parse(raw) : {};
}
function saveRecord(obj) {
  localStorage.setItem("q_records", JSON.stringify(obj));
}

function checkAnswer(btnEl, userAns, correctAns, card, qid) {
  const allBtns = card.querySelectorAll(".ans-btn");
  allBtns.forEach(b => b.disabled = true);
  const rec = getRecord();
  rec[qid] = rec[qid] || { correct: 0, wrong: 0 };

  let resultHTML = "";
  if (userAns === correctAns) {
    btnEl.classList.add("correct");
    rec[qid].correct++;
    resultHTML = `<div class="result-text">✅ 正確，答案：${correctAns}</div>`;
  } else {
    btnEl.classList.add("wrong");
    allBtns.forEach(b => b.dataset.ans === correctAns && b.classList.add("correct"));
    rec[qid].wrong++;
    resultHTML = `<div class="result-text">❌ 錯誤，正確答案：${correctAns}</div>`;
  }
  saveRecord(rec);

  // 顯示結果同解析
  const resultEl = card.querySelector(".result-text");
  const explainEl = card.querySelector(".explain");
  resultEl.outerHTML = resultHTML;
  explainEl.style.display = "block";

  // 更新答題統計
  const r = rec[qid];
  card.querySelector(".stat").innerHTML = `📊 答對 ${r.correct} 次｜答錯 ${r.wrong} 次`;
}

function loadFilteredQuestions(page = 1) {
  currentPage = page;
  const list = document.getElementById("questionList");
  const bar = document.getElementById("pageBar");
  list.innerHTML = "載入中...";
  bar.innerHTML = "";

  const source = document.getElementById("source").value;
  const chapter = document.getElementById("chapter").value;
  const q_no = document.getElementById("q_no").value.trim();
  const diff = document.getElementById("diff").value;

  let filtered = ALL_QUESTIONS.filter(q => {
    if (source && q.source !== source) return false;
    if (chapter && q.chapter !== chapter) return false;
    if (q_no && q.q_no.toString() !== q_no) return false;
    if (diff && q.diff !== diff) return false;
    return true;
  });

  const total = filtered.length;
  const totalPage = Math.ceil(total / PER_PAGE);
  const paginated = filtered.slice((page - 1) * PER_PAGE, page * PER_PAGE);

  list.innerHTML = "";
  const rec = getRecord();

  paginated.forEach(q => {
    const r = rec[q.id] || { correct: 0, wrong: 0 };
    const div = document.createElement("div");
    div.className = "question-card";
    div.innerHTML = `
      <div class="meta">${q.subject}｜${q.chapter}｜題號 ${q.q_no}｜難度 ${q.diff}</div>
      <div class="meta">${q.large_topic}</div>
      <img src="${q.png_link}" alt="">
      <div class="answer-bar">
        <button class="ans-btn" data-ans="A">A</button>
        <button class="ans-btn" data-ans="B">B</button>
        <button class="ans-btn" data-ans="C">C</button>
        <button class="ans-btn" data-ans="D">D</button>
      </div>
      <div class="result-text"></div>
      <div class="explain">解析：${q.explain}</div>
      <div class="stat">📊 答對 ${r.correct} 次｜答錯 ${r.wrong} 次</div>
    `;
    list.appendChild(div);
    div.querySelectorAll(".ans-btn").forEach(btn => {
      btn.onclick = () => checkAnswer(btn, btn.dataset.ans, q.ans, div, q.id);
    });
  });

  let pageHtml = "";
  for (let i = 1; i <= totalPage; i++) {
    pageHtml += `<button class="page-btn" onclick="loadFilteredQuestions(${i})">${i}</button>`;
  }
  bar.innerHTML = pageHtml;
}

loadFilteredQuestions();
</script>
</body>
</html>
